# JSON Web Token secret for admin authentication
JWT_SECRET=your_jwt_secret_here

# PostgreSQL connection string for asyncpg
DATABASE_URL=postgresql://edupredict:edupredict@db:5432/edupredict

# Redis connection string for rate limiting
REDIS_URL=redis://redis:6379/0

# Database name for PostgreSQL initialization
POSTGRES_DB=edupredict

# Database user for PostgreSQL initialization
POSTGRES_USER=edupredict

# Database password for PostgreSQL initialization
POSTGRES_PASSWORD=edupredict

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=edupredict

# API Key for accessing data.gov.in PLFS stats
DATAGOV_API_KEY=your_datagov_key_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# Interval in hours for the data acquisition scheduler
DAG_INTERVAL_HOURS=24

# MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000
