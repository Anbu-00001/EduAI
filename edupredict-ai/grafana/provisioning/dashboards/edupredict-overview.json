{
  "title": "EduPredict Overview",
  "uid": "edupredict-overview",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Decisions per minute",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(edupredict_assess_requests_total[1m]) * 60)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/min",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0 },
              { "color": "green", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(edupredict_assess_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Tenants",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "edupredict_active_tenants",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Risk Tier Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (risk_tier) (rate(edupredict_assess_requests_total[1h]))",
          "refId": "A",
          "legendFormat": "{{risk_tier}}"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 4,
      "title": "Repayment Probability Histogram",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (le) (rate(edupredict_repayment_probability_bucket[1h]))",
          "refId": "A",
          "legendFormat": "{{le}}"
        }
      ],
      "options": {
        "orientation": "vertical",
        "displayMode": "gradient"
      }
    },
    {
      "id": 5,
      "title": "Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(edupredict_assess_latency_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(edupredict_assess_latency_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(edupredict_assess_latency_seconds_bucket[5m])) by (le))",
          "refId": "C",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" }
      }
    }
  ]
}
