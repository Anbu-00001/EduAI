# Paste these into Railway → your service → Variables tab

JWT_SECRET=<run: python -c "import secrets; print(secrets.token_hex(32))">
ALLOWED_ORIGINS=https://your-app-name.railway.app
IMRI_DEFAULT=0.72
RBI_REPO_RATE=0.0625
CPI_EDUCATION=0.051
DAG_INTERVAL_HOURS=6
DAG_CACHE_MAX_AGE_HOURS=12
RATE_LIMIT_DEFAULT_RPM=100
ENABLE_SCHEDULER=false
LOG_LEVEL=INFO

# These are auto-injected by Railway when you add PostgreSQL and Redis plugins:
# DATABASE_URL  ← auto
# REDIS_URL     ← auto

# Optional — leave blank if you don't have these:
DATAGOV_API_KEY=
JANPARICHAY_CLIENT_ID=
JANPARICHAY_CLIENT_SECRET=
DPO_EMAIL=dpo@yourdomain.com
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
