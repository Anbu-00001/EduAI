# app/ui/.env.example — copy to .env and fill in

# API base URL (default: Vite proxy to localhost:8000)
VITE_API_BASE=/v1

# JanParichay OAuth (leave empty to enable demo mode)
VITE_JANPARICHAY_CLIENT_ID=
VITE_JANPARICHAY_REDIRECT_URI=http://localhost:5173/auth/callback

# Hash salt for user_hash generation (any random string)
VITE_HASH_SALT=edupredict-dpdp-2026
